  price     Float // Price for this grid level

  // Order type
  side   String // BUY or SELL
  status String @default("PENDING") // PENDING, OPEN, FILLED, CANCELLED

  // Amount
  amount Float // Amount to buy/sell
  filled Float @default(0) // Filled amount

