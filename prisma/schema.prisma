// ==================== ARGUS BOT ====================
// Automated pump and dump detection and trading
// Named after the mythological hundred-eyed giant who watches everything

model ArgusBot {
  id     String @id @default(cuid())
  userId String
  name   String

  // Status
  status String @default("ACTIVE") // ACTIVE, PAUSED, STOPPED

  // Exchange settings
