// LearningTrade - Record all trades for learning
model LearningTrade {
  id String @id

  // Source of trade
  source  String // 'manual', 'signal', 'bot'
  botCode String? // For signal/bot trades

  // Trade details
  symbol     String
  exchange   String
  direction  String // 'LONG', 'SHORT'
  entryPrice Float
  exitPrice  Float
  size       Float

  // Results
  pnl        Float
  pnlPercent Float
  duration   Int // milliseconds
  timestamp  DateTime
  success    Boolean

  // Context
  marketConditions String? // JSON
  signalConfidence Float?
  signalReason     String?

  createdAt DateTime @default(now())

  @@index([source])
  @@index([botCode])
  @@index([symbol])
  @@index([success])
  @@index([timestamp])
}

// BotPerformance - Track performance of each bot
model BotPerformance {
  id String @id @default(cuid())

  botCode String @unique

  // Signal counts
  totalSignals      Int   @default(0)
  successfulSignals Int   @default(0)
  failedSignals     Int   @default(0)
  accuracy          Float @default(0)

  // PnL metrics
  avgPnl        Float @default(0)
  avgPnlPercent Float @default(0)

  // Condition analysis
  bestConditions  String // JSON array
  worstConditions String // JSON array

  // Symbol preferences
  preferredSymbols String // JSON array
  avoidedSymbols   String // JSON array

  lastUpdated DateTime @updatedAt

  @@index([accuracy])
}

// LearningModel - Store the learning model state
model LearningModel {
  id String @id @default(cuid())

  // Weights and preferences
  botWeights           String // JSON: { "HFT": 0.7, "MFT": 0.5, ... }
  symbolPreferences    String // JSON: { "BTCUSDT": ["HFT", "MFT"], ... }
  conditionMultipliers String // JSON: { "high_volatility": 0.8, ... }
  timePreferences      String // JSON: { "0": 0.5, "1": 0.6, ... }

  totalSamples Int      @default(0)
  lastUpdated  DateTime @updatedAt
}

// ==================== ORDER FILL TRACKING ====================
// Tracks order execution status and fills from exchanges

model OrderFillTracking {
  id String @id @default(cuid())

  // Order identification
  orderId         String  @unique // Internal order ID
  exchangeOrderId String? // Exchange-assigned order ID
  clientOrderId   String? // Client-provided order ID

  // Symbol and exchange
  symbol   String
  exchange String // binance, bybit, okx, bitget, bingx

  // Order details
  side              String // BUY, SELL
  orderType         String // MARKET, LIMIT, STOP_MARKET, STOP_LIMIT, TRAILING_STOP
  requestedQuantity Float
  filledQuantity    Float  @default(0)
  remainingQuantity Float  @default(0)
  limitPrice        Float?

  // Fill information
  avgFillPrice Float  @default(0)
  totalFees    Float  @default(0)
  feeCurrency  String @default("USDT")

  // Status
  status String @default("NEW") // NEW, SUBMITTED, PARTIALLY_FILLED, FILLED, CANCELLED, REJECTED, EXPIRED

  // Fill events (JSON array of FillEvent)
  fills String @default("[]")

  // Position context
  positionSide String? // LONG, SHORT, BOTH (for hedge mode)
  reduceOnly   Boolean @default(false)
  positionId   String?
  signalId     Int?

  // Demo flag
  isDemo Boolean @default(false)

  // Timestamps
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  filledAt  DateTime? // When order was fully filled

  @@index([exchangeOrderId])
  @@index([clientOrderId])
  @@index([symbol, exchange])
  @@index([positionId])
  @@index([signalId])
  @@index([status])
  @@index([createdAt])
}

// SignalEntryTracking - Tracks fill status for signal entry prices
model SignalEntryTracking {
  id String @id @default(cuid())

  // Signal reference
  signalId   Int
  entryIndex Int // Index of the entry price in the signal

  // Entry details
  entryPrice        Float
  requestedQuantity Float
  filledQuantity    Float @default(0)
  avgFillPrice      Float @default(0)

  // Status
  isFilled Boolean @default(false)

  // Associated orders (JSON array of order IDs)
  orderIds String @default("[]")

  // Timestamps
  firstFillAt DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([signalId, entryIndex])
  @@index([signalId])
  @@index([isFilled])
}

// ==================== TP GRACE STATE ====================
// Tracks Take-Profit Grace retry state for positions

model TPGraceState {
  id         String @id @default(cuid())
  positionId String @unique
  symbol     String
  direction  String // LONG, SHORT
  status     String @default("ACTIVE") // ACTIVE, COMPLETED, CANCELLED

  // TP Targets as JSON array
  targets String // JSON: [{index, price, percentage, filled, retries, originalPrice, status}]

  // Tracking
  lastRetryAt DateTime?
  retryCount  Int       @default(0)
  totalFilled Float     @default(0)

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  position Position @relation(fields: [positionId], references: [id], onDelete: Cascade)
}

// ==================== TRAILING STATE ====================
// Tracks trailing stop state for positions

model TrailingState {
  id         String @id @default(cuid())
  positionId String @unique
  symbol     String
  direction  String // LONG, SHORT

  // Trailing Type
  trailingType String // BREAKEVEN, MOVING_TARGET, MOVING_2_TARGET, PERCENT_BELOW_TRIGGERS, PERCENT_BELOW_HIGHEST
  status       String @default("INACTIVE") // INACTIVE, TRIGGERED, ACTIVE, COMPLETED, CANCELLED

  // Prices
  entryPrice       Float
  highestPrice     Float?
  lowestPrice      Float?
  currentStopLoss  Float
  originalStopLoss Float

  // Trigger
  triggerType      String? // TARGET_REACHED, PERCENT_ABOVE_ENTRY
  triggerValue     Float?
  triggerTargetHit Int? // Which TP target was hit
  triggeredAt      DateTime?

  // Trailing parameters
  trailingPercent  Float?
  trailingDistance Float?

  // Stats
  updateCount  Int       @default(0)
  lastUpdateAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  position Position @relation(fields: [positionId], references: [id], onDelete: Cascade)
}

// ==================== FIRST ENTRY ITERATION ====================
// Tracks iterative entry attempts for First Entry as Market feature

model FirstEntryIteration {
  id         String  @id @default(cuid())
  signalId   Int
  positionId String? @unique

  // Iteration tracking
  iteration      Int   @default(0)
  maxIterations  Int
  iterationPrice Float // Current iteration price
  originalPrice  Float // Original entry price
  cappedPrice    Float // Maximum allowed price

  // Status
  status String @default("PENDING") // PENDING, FILLED, EXHAUSTED, CANCELLED

  // Execution
  executedPrice Float?
  executedAt    DateTime?

  // Direction
  direction String // LONG, SHORT

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  signal   Signal    @relation(fields: [signalId], references: [signalId], onDelete: Cascade)
  position Position? @relation(fields: [positionId], references: [id], onDelete: SetNull)
}

// ==================== ORDER EXECUTION ====================
// Tracks order execution details and status from exchanges

model OrderExecution {
  id         String  @id @default(cuid())
  positionId String?
  signalId   Int?

  // Order details
  exchange        String // binance, bybit, okx
  exchangeOrderId String? @unique
  clientOrderId   String?
  symbol          String
  side            String // BUY, SELL
  type            String // MARKET, LIMIT, STOP_MARKET, etc.

  // Amounts
  requestedAmount Float
  filledAmount    Float  @default(0)
  remainingAmount Float  @default(0)
  price           Float?
  avgFillPrice    Float?

  // Status
  status String @default("PENDING") // PENDING, PARTIALLY_FILLED, FILLED, CANCELLED, REJECTED, EXPIRED

  // Timestamps
  createdAt   DateTime  @default(now())
  submittedAt DateTime?
  filledAt    DateTime?
  cancelledAt DateTime?

  // Error tracking
  errorCode    String?
  errorMessage String?

  // Metadata
  metadata String? // JSON for additional info

  position Position? @relation(fields: [positionId], references: [id], onDelete: SetNull)

  @@index([exchangeOrderId])
  @@index([symbol, exchange])
  @@index([positionId])
  @@index([signalId])
  @@index([status])
  @@index([createdAt])
}
